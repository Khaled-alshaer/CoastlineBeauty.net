@model Product


<form method="post">
    <input asp-for="ProductId" hidden/>
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Delete Product</h2>
        </div>

        <div class="mb-3">
            <label asp-for="Brand"></label>
            <input asp-for="Brand" disabled class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Name"></label>
            <input asp-for="Name" disabled class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Size"></label>
            <input asp-for="Size" disabled class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Type"></label>
            <input asp-for="Type" disabled class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Gender"></label>
            <input asp-for="Gender" disabled class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Price"></label>
            <input asp-for="Price" disabled class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Quantity"></label>
            <input asp-for="Quantity" disabled class="form-control" />
        </div>

        <button type="submit" class="btn btn-danger form-control" style="width:150px">Delete</button>
        <a asp-controller="Product" asp-action="Index" class="btn btn-secondary border form-control" style="width:150px">Back to List</a>
    </div>
</form>
