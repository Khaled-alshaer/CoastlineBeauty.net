@model List<Product>


<div class="container">
    <div class="row pt-6 pb-2">
        <div class="col-6">
            <h2 class="text-primary">Product List</h2>
        </div>
    
        <div class="col-12 text-end">
        <a asp-controller="Product" asp-action="Create" class="btn btn-primary">
            Create New Product
        </a>
        </div>
    </div>

<table class="table table-bordered table-striped">
    <thead>
    <tr>
        <th>Product ID</th>
        <th>Brand</th>
        <th>Name</th>
        <th>Size</th>
        <th>Type</th>
        <th>Gender</th>
        <th>Price</th>
        <th>Quantity</th>
    </tr>
    </thead>
    <tbody>
        @foreach (var obj in Model.OrderBy(i=>i.Brand))
        {
            <tr>
               <td>@obj.ProductId</td>
                <td>@obj.Brand</td>
                <td>@obj.Name</td>
                <td>@obj.Size</td>
                <td>@obj.Type</td>
                <td>@obj.Gender</td>
                <td>$@obj.Price.ToString("0.00")</td>
                <td>@obj.Quantity</td>
                <td>
                    <div class="w-100 btn-group" role="group">
                        <a asp-controller="Product" asp-action="Edit" asp-route-ProductId="@obj.ProductId" class="btn btn-primary mx-1">Edit</a>
                        <a asp-controller="Product" asp-action="Delete" asp-route-ProductId="@obj.ProductId" class="btn btn-danger mx-1">Delete</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>

</table>

</div>